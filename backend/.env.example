# Environment Variables
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/retro_collection_tracker?schema=public"
JWT_SECRET="change-me-to-a-secure-random-string"
JWT_EXPIRATION="7d"
PORT=3000
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# External game search (sign up for free key at https://rawg.io/apidocs)
# Falls back to Wikipedia if not set (limited data)
RAWG_API_KEY="your-rawg-api-key-here"

# Donation display values (optional)
DONATE_RAISED=247
DONATE_GOAL=500
DONATE_SUPPORTERS=34

# Cloudflare R2 — optional, enables persistent S3-compatible file storage
# R2_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
# R2_ACCESS_KEY="..."
# R2_SECRET_KEY="..."
# R2_BUCKET="retro-collection"
# R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"
