generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ─────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum OwnershipStatus {
  OWNED
  WISHLIST
  FOR_SALE
  TRADED
}

enum Condition {
  MINT
  NEAR_MINT
  VERY_GOOD
  GOOD
  ACCEPTABLE
  POOR
  MISSING_PARTS
}

enum Region {
  NTSC
  PAL
  NTSC_J
  REGION_FREE
}

enum ActivityType {
  ADDED_GAME
  REMOVED_GAME
  UPDATED_GAME
  ADDED_REVIEW
  ADDED_WISHLIST
  REMOVED_WISHLIST
  FOLLOWED_USER
  UNFOLLOWED_USER
  CREATED_ACCOUNT
  UPDATED_PROFILE
}

enum TradeStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  SHIPPED
  COMPLETED
}

enum NotificationType {
  NEW_FOLLOWER
  NEW_REVIEW
  WISHLIST_AVAILABLE
  COLLECTION_UPDATE
  SYSTEM
}

// ─── MODELS ───────────────────────────────────

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  username    String    @unique
  displayName String?
  password    String
  bio         String?
  avatarUrl   String?
  location    String?
  role        UserRole  @default(USER)
  isActive              Boolean   @default(true)
  isEmailVerified       Boolean   @default(false)
  emailVerificationToken String?
  emailChangeCount      Int       @default(0)
  xp                Int       @default(0)
  lastLoginAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  collections       Collection[]
  wishlists         Wishlist[]
  reviews           Review[]
  reviewLikes       ReviewLike[]
  reviewComments    ReviewComment[] @relation("UserReviewComments")
  sentMessages      Message[]    @relation("sent_messages")
  receivedMessages  Message[]    @relation("received_messages")
  blocksInitiated   Block[]      @relation("blocker")
  blocksReceived    Block[]      @relation("blocked")
  reportsMade       Report[]     @relation("reporter")
  reportsReceived   Report[]     @relation("reported")
  sentTrades        TradeRequest[] @relation("sent_trades")
  receivedTrades    TradeRequest[] @relation("received_trades")
  followers         Follow[]     @relation("Following")
  following         Follow[]       @relation("Follower")
  activityLogs      ActivityLog[]
  notifications          Notification[]            @relation("NotificationRecipient")
  sentNotifications      Notification[]            @relation("NotificationSender")
  notificationPreference NotificationPreference?

  @@index([email])
  @@index([username])
  @@index([deletedAt])
  @@map("users")
}

model Platform {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  manufacturer String?
  releaseYear  Int?
  createdAt    DateTime @default(now())

  games Game[]

  @@map("platforms")
}

model Genre {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  games Game[]

  @@map("genres")
}

model Game {
  id            String   @id @default(uuid())
  title         String
  platformId    String
  genreId       String
  releaseYear   Int
  developer     String?
  publisher     String?
  description   String?
  coverImageUrl String?
  rawgRating    Float?
  rawgMetacritic Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  platform    Platform     @relation(fields: [platformId], references: [id])
  genre       Genre        @relation(fields: [genreId], references: [id])
  collections Collection[]
  wishlists   Wishlist[]
  reviews     Review[]
  tradeOffers TradeRequest[] @relation("offered_game")
  tradeWants  TradeRequest[] @relation("wanted_game")

  @@index([title])
  @@index([platformId])
  @@index([genreId])
  @@index([releaseYear])
  @@map("games")
}

model Collection {
  id              String          @id @default(uuid())
  userId          String
  gameId          String
  condition       Condition       @default(GOOD)
  region          Region          @default(NTSC)
  notes           String?
  personalRating  Int?            @db.SmallInt
  estimatedValue  Float?          @db.Real
  ownershipStatus OwnershipStatus @default(OWNED)
  coverImage      String?
  acquiredAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Restrict)

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
  @@index([estimatedValue])
  @@map("collections")
}

model Wishlist {
  id       String   @id @default(uuid())
  userId   String
  gameId   String
  priority Int      @default(0) @db.SmallInt
  notes    String?
  estimatedValue Float?
  addedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Restrict)

  @@unique([userId, gameId])
  @@index([userId])
  @@map("wishlists")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  rating    Int      @db.SmallInt
  title     String?
  body      String?
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  game       Game         @relation(fields: [gameId], references: [id], onDelete: Restrict)
  reviewLikes ReviewLike[]
  comments      ReviewComment[] @relation("review_comments")

  @@unique([userId, gameId])
  @@index([gameId])
  @@index([userId])
  @@index([rating])
  @@map("reviews")
}

model ReviewLike {
  id        String   @id @default(uuid())
  userId    String
  reviewId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
  @@index([reviewId])
  @@map("review_likes")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model ActivityLog {
  id         String       @id @default(uuid())
  userId     String
  type       ActivityType
  /// ID of the related entity (game, user, etc.). Not a foreign key — targets may be deleted.
  targetId   String?
  /// Model name of the related entity (e.g. "Game", "User"). Used for polymorphic lookups.
  targetType String?
  message    String?
  metadata   Json?
  createdAt  DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([type])
  @@map("activity_logs")
}

model Notification {
  id          String           @id @default(uuid())
  recipientId String
  senderId    String?
  type        NotificationType
  title       String
  body        String?
  isRead      Boolean          @default(false)
  link        String?
  metadata    Json?
  createdAt   DateTime         @default(now())

  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  sender    User? @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([recipientId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationPreference {
  id        String  @id @default(uuid())
  userId    String  @unique
  email     Boolean @default(true)
  push      Boolean @default(false)
  follows   Boolean @default(true)
  reviews   Boolean @default(true)
  wishlist  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  imageUrl   String?
  readAt     DateTime?
  createdAt  DateTime @default(now())

  sender   User @relation("sent_messages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("received_messages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([senderId, receiverId])
  @@map("messages")
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocks")
}

model Report {
  id         String   @id @default(uuid())
  reporterId String
  reportedId String
  reason     String?
  createdAt  DateTime @default(now())

  reporter User @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("reported", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([reportedId])
  @@map("reports")
}

model ReviewComment {
  id        String   @id @default(uuid())
  reviewId  String
  userId    String
  content   String
  createdAt DateTime @default(now())

  user   User   @relation("UserReviewComments", fields: [userId], references: [id], onDelete: Cascade)
  review Review @relation("review_comments", fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([userId])
  @@map("review_comments")
}

model TradeRequest {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  offeredGameId String?
  wantedGameId String?
  message     String?
  status      TradeStatus @default(PENDING)
  shippingMethod String?
  senderAddress  String?
  receiverAddress String?
  trackingNumber String?
  shippingNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sender   User   @relation("sent_trades", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User   @relation("received_trades", fields: [receiverId], references: [id], onDelete: Cascade)
  offered  Game?  @relation("offered_game", fields: [offeredGameId], references: [id], onDelete: SetNull)
  wanted   Game?  @relation("wanted_game", fields: [wantedGameId], references: [id], onDelete: SetNull)

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@map("trade_requests")
}