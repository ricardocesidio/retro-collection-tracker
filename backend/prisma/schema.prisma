generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OwnershipStatus {
  OWNED
  WISHLIST
  FOR_SALE
  TRADED
}

enum Condition {
  MINT
  NEAR_MINT
  VERY_GOOD
  GOOD
  ACCEPTABLE
  POOR
  MISSING_PARTS
}

enum Region {
  NTSC
  PAL
  NTSC_J
  REGION_FREE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String
  bio       String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  collections Collection[]
  wishlists   Wishlist[]
  reviews     Review[]
  followers   Follow[]   @relation("Following")
  following   Follow[]   @relation("Follower")

  @@map("users")
}

model Game {
  id          String   @id @default(uuid())
  title       String
  platform    String
  genre       String
  releaseYear Int
  developer   String?
  publisher   String?
  description String?
  coverImageUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  collections Collection[]
  wishlists   Wishlist[]
  reviews     Review[]

  @@map("games")
}

model Collection {
  id              String          @id @default(uuid())
  userId          String
  gameId          String
  condition       Condition       @default(GOOD)
  region          Region          @default(NTSC)
  notes           String?
  personalRating  Int?
  estimatedValue  Float?
  ownershipStatus OwnershipStatus @default(OWNED)
  coverImage      String?
  acquiredAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@map("collections")
}

model Wishlist {
  id       String   @id @default(uuid())
  userId   String
  gameId   String
  priority Int      @default(0)
  notes    String?
  addedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@map("wishlists")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  rating    Int
  title     String?
  body      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@map("reviews")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}
